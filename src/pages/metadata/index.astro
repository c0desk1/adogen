---
import { 
  buildMeta, 
  schemaSoftwareApplication, 
  schemaBreadcrumb, 
  SITE, 
  ROUTES 
} from '@/consts';

import ToolsLayout from '@/layouts/ToolsLayout.astro';
import Container from '@/components/ui/Container.astro';
import Drawer from '@/app/components/ui/Drawer';
import Dropzone from '@/app/components/workspace/Dropzone';
import StatusBar from '@/app/components/workspace/StatusBar';
import Output from '@/app/components/workspace/Output';
import SearchFilterBar from '@/app/components/workspace/SearchFilterBar';
import Section from '@/components/ui/Section.astro';
import Toolbar from '@/app/components/workspace/Toolbar';
import SettingsPanel from '@/app/components/workspace/SettingsPanel';

const meta = buildMeta({
  title: 'Metadata Generator',
  description: 'Generate SEO-optimized titles, keywords, and categories for microstock images using AI vision models. Bring your own API key – supports Groq, Mistral, OpenRouter, Google Gemini, and Cloudflare.',
  canonical: `${SITE.url}${ROUTES.metadata}`,
  ogType: 'website',
  keywords: ['metadata generator', 'AI metadata', 'microstock keywords', 'image keywords', 'stock photography SEO'],
});

const schema = [
  schemaSoftwareApplication({
    name: `${SITE.name} Metadata Generator`,
    description: meta.description,
    url: `${SITE.url}${ROUTES.metadata}`,
    image: SITE.ogImage,
    applicationCategory: 'DesignApplication',
    price: '0',
  }),
  schemaBreadcrumb([
    { name: 'Home', url: SITE.url },
    { name: 'Metadata Generator', url: `${SITE.url}${ROUTES.metadata}` },
  ]),
];

---

<ToolsLayout {meta} {schema} hideFooter hideHeader>
  <Toolbar client:only="react" />
  <Container size='full'>
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_24rem] gap-4 px-0">
      <div class="w-full mx-auto min-w-0 px-0 overflow-y-auto">
        <Section size="sm">
          <StatusBar client:only="react" />
          <div class="sticky top-0 z-30 bg-(--bg)">
            <SearchFilterBar client:only="react" />
          </div>
        </Section>
        <Section size="md">
          <Container size='full' class='px-0!'>
            <Dropzone client:only="react" />
            <div class="max-w-none min-w-0 wrap-break-words">
              <Output client:only="react" />
            </div>
          </Container>
        </Section>
      </div>
      <div class="hidden sm:block shrink-0 lg:gap-x-8">
        <SettingsPanel client:only="react" />
      </div>
    </div>
  </Container>
  <Drawer client:only="react" />
</ToolsLayout>