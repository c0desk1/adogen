---
// src/pages/[slug].astro
export const prerender = true;

import { 
  getCollection, 
  render 
} from 'astro:content';

import { 
  buildMeta, 
  schemaWebPage, 
  SITE, 
  formatDate 
} from '../consts';

import { components } from '@/components/mdx/MDXComponents.astro';

import Layout from '@/layouts/Layout.astro';
import Container from '@/components/ui/Container.astro';

export async function getStaticPaths() {
  const legalEntries = await getCollection('legal');
  return legalEntries.map(entry => ({
    params: { slug: entry.data.slug || entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;

if (!entry) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const { Content } = await render(entry);

const currentSlug = Astro.params.slug;
const currentUrl = `${SITE.url}/${currentSlug}`;

const metaProps = buildMeta({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  canonical: currentUrl,
});

const pageSchema = schemaWebPage({
  title: entry.data.title,
  description: entry.data.description || SITE.description,
  url: currentUrl,
});
---

<Layout meta={metaProps} schema={pageSchema}>
  <Container size='md'>
    <div class="py-12 md:py-16">
      <header class="mb-8">
        <h1 class="text-3xl sm:text-4xl font-bold text-(--fg-strong) tracking-tight mb-3">
          {entry.data.title}
        </h1>
        
        <div class="flex flex-wrap items-center gap-4 text-xs text-(--fg-muted) mt-2">
          {entry.data.description && (
            <p class="text-sm text-(--fg-muted) border-b border-none pb-0 mb-0">
              {entry.data.description}
            </p>
          )}
          
          {entry.data.lastUpdated && (
            <div class="flex items-center gap-1.5 bg-(--bg-subtle) border border-(--border)/60 px-2.5 py-1 rounded-md font-medium">
              <span>Last updated:</span>
              <time datetime={entry.data.lastUpdated.toISOString()}>
                {formatDate(entry.data.lastUpdated)}
              </time>
            </div>
          )}
        </div>
      </header>
      <div class="h-px bg-(--border)/60 my-6" />
      <article class="prose">
        <Content components={components}/>
      </article>
    </div>
  </Container>
</Layout>
