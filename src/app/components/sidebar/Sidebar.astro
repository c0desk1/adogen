---
// src/components/Sidebar.astro
import { 
  NAV, 
  SITE 
} from '@/consts';

import { cn } from '@/lib/utils';
import Icon from '@/app/components/ui/Icon';

const currentPath = Astro.url.pathname;

---
<div id="tools-sidebar" class="inline-flex shrink-0 border-r border-(--border-subtle) bg-(--bg-subtle) select-none">
  <div
    id="tools-sidebar"
    class="flex flex-col h-full bg-(--bg-surface) overflow-hidden transition-[width] duration-200 ease-in-out fixed top-0 left-0 z-50">
    <div class="flex items-center gap-0.5 p-2 shrink-0">
      <a href='/' class="flex items-center gap-4 px-2 py-2 w-full rounded-md hover:bg-(--bg-muted)">
        <Icon name="askAIAgent" className="w-4 h-4" />
        <span class="sidebar-text font-mono uppercase font-semibold text-sm text-(--fg) whitespace-nowrap">
          {SITE.name}
        </span>
      </a>
    </div>
    <nav class="flex flex-col gap-0.5 p-2 space-y-1 flex-1 overflow-y-auto overflow-x-hidden">
      {NAV.toolsNav.map((item) => {
        const isActive = currentPath === item.href;
        return (
          <a
            href={item.href}
            class={cn(
              "nav-item relative flex items-center gap-4 px-2 py-1.5 rounded-md text-[14px] transition-colors w-full",
              isActive 
                ? "bg-(--bg-muted) text-(--fg-strong) font-semibold" 
                : "text-(--fg-muted) hover:bg-(--bg-muted)/80 hover:text-(--fg)"
            )}
          > 
            <Icon name={item.icon as any} className="w-4 h-4" />
            <span class="sidebar-text whitespace-nowrap">{item.label}</span>
            {isActive && <span class="ml-auto w-1.5 h-1.5 rounded-full bg-(--accent)" />}
          </a>
        );
      })}
    </nav>
  </div>
</div>

<script>
  function toggleSidebar() {
    const isCollapsed = document.documentElement.getAttribute('data-sidebar') === 'collapsed';
    const newState = isCollapsed ? 'expanded' : 'collapsed';
    
    document.documentElement.setAttribute('data-sidebar', newState);
    document.cookie = `sidebar_state=${newState}; path=/; max-age=604800; SameSite=Lax`;
  }

  document.querySelector('#sidebar-trigger')?.addEventListener('click', toggleSidebar);
</script>

<style is:global>
  #tools-sidebar {
    transition: width 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: width;
  }
  [data-sidebar="collapsed"] #tools-sidebar { 
    width: 48px; 
  }
  [data-sidebar="expanded"] #tools-sidebar { 
    width: 224px; 
  }

  [data-sidebar="collapsed"] .sidebar-text {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.1s ease-out;
  }
  [data-sidebar="expanded"] .sidebar-text {
    opacity: 1;
    transition: opacity 0.2s ease-in;
  }
  @media (max-width: 640px) {
    [data-sidebar="collapsed"] #tools-sidebar { width: 0px; }
  }
</style>