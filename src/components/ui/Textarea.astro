---
// src/components/ui/Textarea.astro
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'textarea'> {
  label?: string;
  error?: string;
  value?: string;
}

const {
  label,
  error,
  id,
  class: className,
  value,
  ...rest
} = Astro.props;

const showLabel = typeof label === 'string' && label.trim().length > 0;

const autoId = id ?? (showLabel ? `textarea-${label!.toLowerCase().replace(/\s+/g, '-')}` : undefined);
---

<div class="flex flex-col gap-2">
  {showLabel && (
    <label
      for={autoId}
      class="text-[13px] font-medium text-(--fg) mb-2"
    >
      {label}
    </label>
  )}
  <textarea
    id={autoId}
    class:list={[
      "min-h-20 px-3 py-2 rounded-(--radius) border border-(--border) placeholder:text-[13px]",
      "bg-(--bg) text-(--fg)",
      "focus:outline-none focus:ring-2 focus:ring-(--accent-ring)",
      error ? "border-(--error)" : "",
      className,
    ]}
    {...rest}
  >{value ?? ''}</textarea>

  {error && (
    <p class="text-[13px] font-medium text-(--error)">
      {error}
    </p>
  )}
</div>