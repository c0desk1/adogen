---
// src/components/ui/Input.astro
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'input'> {
  label?: string;
  error?: string;
  helper?: string;
}

const {
  label,
  error,
  helper,
  id,
  type = 'text',
  class: className,
  ...rest
} = Astro.props;

const inputId = id || label?.toLowerCase().replace(/\s+/g, '-');
const isPassword = type === 'password';
const hasIconSlot = Astro.slots.has('icon');
---

<div class="flex flex-col gap-1.5 w-full" data-input-root>
  {label && (
    <label for={inputId} class="text-[13px] font-medium text-(--fg) mb-2">
      {label}
    </label>
  )}
  
  <div class="relative flex items-center w-full">
    {hasIconSlot && (
      <div class="absolute left-3 pointer-events-none text-(--fg-dim) flex items-center justify-center z-10">
        <slot name="icon" />
      </div>
    )}

    <input
      id={inputId}
      type={type}
      class:list={[
        "w-full h-9 rounded-md border border-(--border) bg-transparent text-[13px] text-(--fg-strong) placeholder:text-(--fg-dim) placeholder:text-[13px] transition-colors",
        "focus:outline-none focus:ring-2 focus:ring-(--accent-ring) focus:border-(--accent)",
        "disabled:opacity-40 disabled:cursor-not-allowed",
        hasIconSlot ? "pl-9" : "pl-3",
        isPassword ? "pr-10" : "pr-3",
        error ? "border-(--error) text-(--error) focus:border-(--error) focus:ring-(--error)" : "",
        className,
      ]}
      {...rest as HTMLAttributes<'input'>}
    />

    {isPassword && (
      <button
        type="button"
        data-password-toggle
        aria-label="Toggle password visibility"
        class="absolute right-1.5 p-1.5 text-(--fg-dim) hover:text-(--fg-strong) transition-colors rounded-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-(--border) cursor-pointer z-10"
      >
        <svg data-eye-open class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        
        <svg data-eye-close class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
        </svg>
      </button>
    )}
  </div>

  {(error || helper || Astro.slots.has('helper')) && (
    <div class="flex flex-col gap-1 mt-2">
      {error && <p class="text-[12px] font-medium text-(--error) animate-in fade-in">{error}</p>}
      {(helper || Astro.slots.has('helper')) && (
        <div class="text-[12px] text-(--fg-muted)">
          {helper || <slot name="helper" />}
        </div>
      )}
    </div>
  )}
</div>

<script>
  const initInputFeatures = () => {
    const inputRoots = document.querySelectorAll('[data-input-root]');

    inputRoots.forEach((root) => {
      const toggleBtn = root.querySelector('[data-password-toggle]') as HTMLButtonElement | null;
      const input = root.querySelector('input') as HTMLInputElement | null;
      
      if (!toggleBtn || !input) return;

      const eyeOpenIcon = toggleBtn.querySelector('[data-eye-open]');
      const eyeCloseIcon = toggleBtn.querySelector('[data-eye-close]');

      if (toggleBtn.dataset.bound === '1') return;
      toggleBtn.dataset.bound = '1';

      toggleBtn.addEventListener('click', () => {
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';

        if (eyeOpenIcon && eyeCloseIcon) {
          eyeOpenIcon.classList.toggle('hidden', isPassword);
          eyeCloseIcon.classList.toggle('hidden', !isPassword);
        }
      });
    });
  };

  initInputFeatures();
  document.addEventListener("astro:page-load", initInputFeatures);
  if (document.readyState !== 'loading') initInputFeatures();
</script>