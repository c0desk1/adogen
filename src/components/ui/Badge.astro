---
// src/components/ui/Badge.astro
import type { HTMLAttributes } from 'astro/types';
import { cn } from '@/lib/cn';

type BadgeVariant = 'default' | 'accent' | 'success' | 'warning' | 'error';

interface Props extends HTMLAttributes<'span'> {
  variant?: BadgeVariant;
  class?: string;
}

const { 
  variant = 'default', 
  class: className, 
  ...rest 
} = Astro.props;

const baseClasses = "inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full transition-colors";

const variantClasses: Record<BadgeVariant, string> = {
  default: "bg-(--bg-subtle) text-(--fg-strong)",
  accent:  "bg-(--accent-soft) text-(--accent)",
  success: "bg-(--success-soft) text-(--success)",
  warning: "bg-(--warning-soft) text-(--warning)",
  error:   "bg-(--error-soft) text-(--error)",
};

const combinedClasses = cn(baseClasses, variantClasses[variant], className);
---

<span class={combinedClasses} {...rest}>
  <slot />
</span>