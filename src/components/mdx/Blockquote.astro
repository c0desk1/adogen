---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import { cdnImage, isCdnUrl } from '@/lib/utils';
import Icon from '@/components/ui/icons/Icon.astro';

interface Props {
  authorSlug?: string;
  authorName?: string;
  cite?: string;
  citeLabel?: string;
}

const { cite, citeLabel } = Astro.props;


const showCredit = cite || citeLabel;
---

<blockquote class="quote" cite={cite}>
  <div class="quote-body text-body-20 font-medium">
    <slot />
  </div>
  {showCredit && (
    <div class="quote-footer">
      {cite && (
        <div class="quote-cite">
          <a href={cite} target="_blank" rel="noopener noreferrer">
            {citeLabel || 'Source'}
            <Icon name="external" className="w-3 h-3 ml-1" />
          </a>
        </div>
      )}
      {!cite && citeLabel && (
        <div class="quote-cite">
          <span>{citeLabel}</span>
        </div>
      )}
    </div>
  )}
</blockquote>