---
// src/components/docs/DocsMobileNav.astro
import type { CollectionEntry } from "astro:content";
import Icon from '../ui/Icon.astro';
import { ROUTES, SITE } from '../../consts';
import Button from "../ui/Button.astro";

interface Props {
  sidebarItems: CollectionEntry<"docs">[];
  primaryRootId: string;
  cleanSlug: string | undefined;
}

const { sidebarItems, primaryRootId, cleanSlug } = Astro.props;

const generalLinks = [
  { label: 'Home', href: ROUTES.home },
  { label: 'Docs', href: ROUTES.docs },
  { label: 'Privacy Policy', href: ROUTES.privacy },
  { label: 'Terms of Service', href: ROUTES.terms },
];

const toolLinks = [
  { label: 'Metadata Generator', href: ROUTES.metadata },
  { label: 'Image Upscaler', href: ROUTES.upscale },
];
---

<Button 
  type="button" 
  id="mobile-menu-open" 
  aria-label="Open menu" 
  variant="icon-outline"
  size="sm"
  class="inline-flex shrink-0 items-center p-1.5 cursor-pointer sm:hidden"
  >
  <Icon name="menu" className="w-full h-full" />
</Button>

<div id="mobile-menu-drawer" class="fixed inset-0 z-50 bg-(--bg) flex flex-col opacity-0 pointer-events-none transition-all duration-300 invisible">
  <header class="flex items-center justify-between px-4 h-(--header-height) shrink-0 border-b border-(--border)/50">
    <a href={ROUTES.home} aria-label={SITE.name} class="inline-flex shrink-0 items-center gap-1.5 font-medium text-xl text-(--fg) hover:opacity-80 transition-opacity">
      <Icon name="logo" className='w-6 h-6' />
    </a>
    <Button
      type="button"
      id="mobile-menu-close"
      aria-label="Close menu"
      variant="icon-outline"
      size="sm"
      class="inline-flex shrink-0 items-center p-1.5 cursor-pointer sm:hidden"
    >
      <Icon name="close" className="w-full h-full" />
    </Button>
  </header>
  <nav class="flex-1 overflow-y-auto py-6 px-4 flex flex-col gap-6">
    <p class="text-[13px] font-medium font-mono text-(--fg) uppercase">
      Docs
    </p>
    <ul class="flex flex-col gap-0.5 border-l border-(--border)/60">
      {sidebarItems.map(item => {
        const itemSlug = item.data.slug || item.id;
        const isItemRoot = item.id === primaryRootId;
        const targetHref = isItemRoot ? '/docs' : `/docs/${itemSlug}`;
        const isActive = isItemRoot ? !cleanSlug : cleanSlug === itemSlug;
        return (
          <li>
            <a 
              href={targetHref}
              aria-label={item.data.title}
              class:list={[
                "mobile-nav-link flex items-center justify-between gap-2 px-3 py-1.5 text-[14px] no-underline transition-all border-l-2 -ml-px rounded-r-md", 
                isActive 
                  ? "bg-(--accent)/10 text-(--accent) font-medium border-(--accent) shadow-xs"
                  : "text-(--fg-muted) hover:text-(--fg-strong) hover:bg-(--bg-muted)/40 border-transparent"
              ]}
            >
              <span class="truncate leading-snug">{item.data.title}</span>
            </a>
          </li>
        );
      })}
    </ul>
    <div class="border-t border-(--border-subtle) pt-4 mb-1">
      <p class="text-[13px] font-medium font-mono text-(--fg) uppercase mb-2 px-3">
        Tools
      </p>
      <ul class="flex flex-col gap-0.5">
        {toolLinks.map(link => (
          <li>
            <a 
              href={link.href}
              aria-label={link.label}
              class="mobile-nav-link flex items-center justify-between gap-2 px-3 py-1.5 text-[14px] font-medium no-underline transition-all text-(--fg-muted) hover:text-(--fg-strong) hover:bg-(--bg-muted)/40 rounded-md"
            >
              <span class="truncate leading-snug">{link.label}</span>
              <span class="w-3 h-3 text-(--fg-dim) shrink-0">
                <Icon name="askAIAgent" className="w-full h-full" />
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
    <div class="border-t border-(--border-subtle) pt-4">
      <p class="text-[13px] font-medium font-mono text-(--fg) uppercase mb-2 px-3">
        General
      </p>
      <ul class="flex flex-col gap-0.5">
        {generalLinks.map(link => (
          <li>
            <a 
              href={link.href}
              aria-label={link.label}
              class="mobile-nav-link flex items-center justify-between gap-2 px-3 py-1.5 text-[14px] font-medium no-underline transition-all text-(--fg-muted) hover:text-(--fg-strong) hover:bg-(--bg-muted)/40 rounded-md"
            >
              <span class="truncate leading-snug">{link.label}</span>
              <span class="w-3 h-3 text-(--fg-dim) shrink-0">
                <Icon name="logo" className="w-full h-full" />
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</div>

<script>
  function initDocsMobileNav() {
    const openBtn = document.getElementById('mobile-menu-open');
    const closeBtn = document.getElementById('mobile-menu-close');
    const drawer = document.getElementById('mobile-menu-drawer');
    const links = document.querySelectorAll('.mobile-nav-link');

    if (!openBtn || !closeBtn || !drawer) return;

    if (drawer.parentElement !== document.body) {
      document.body.appendChild(drawer);
    }

    const openMenu = () => {
      drawer.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
      drawer.classList.add('opacity-100', 'pointer-events-auto', 'visible');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      drawer.classList.remove('opacity-100', 'pointer-events-auto', 'visible');
      drawer.classList.add('opacity-0', 'pointer-events-none', 'invisible');
      document.body.style.overflow = '';
    };

    openBtn.onclick = openMenu;
    closeBtn.onclick = closeMenu;
    links.forEach(link => {
      (link as HTMLElement).onclick = closeMenu;
    });

    const mq = window.matchMedia('(min-width: 640px)');
    mq.onchange = (e) => { if (e.matches) closeMenu(); };
  }
  initDocsMobileNav();
  document.addEventListener('astro:page-load', initDocsMobileNav);
  if (document.readyState !== 'loading') initDocsMobileNav();
</script>