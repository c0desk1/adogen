---
import Icon from '../ui/Icon.astro';

// src/components/ui/ScrollToTopFloating.astro
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<button
  type="button"
  id="scroll-to-top-floating"
  class:list={[
    "fixed bottom-6 right-6 z-50 md:hidden flex items-center justify-center w-10 h-10 p-1.5 rounded-md bg-(--surface) border border-(--border)/60 text-(--fg-muted) hover:bg-(--bg-muted) active:bg-(--bg-muted) shadow-xl transition-all duration-300 transform translate-y-10 opacity-0 pointer-events-none focus:outline-none cursor-pointer",
    className
  ]}
  aria-label="Scroll to top"
>
  <Icon name='arrow-up' className='w-full h-full' />
</button>

<script>
  const initFloatingBackToTop = () => {
    const button = document.getElementById('scroll-to-top-floating');
    if (!button) return;

    const toggleVisibility = () => {
      if (window.scrollY > 300) {
        button.classList.remove('translate-y-10', 'opacity-0', 'pointer-events-none');
        button.classList.add('translate-y-0', 'opacity-100');
      } else {
        button.classList.add('translate-y-10', 'opacity-0', 'pointer-events-none');
        button.classList.remove('translate-y-0', 'opacity-100');
      }
    };

    const scrollToTop = () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    };

    window.addEventListener('scroll', toggleVisibility, { passive: true });
    button.addEventListener('click', scrollToTop);

    toggleVisibility();

    return () => {
      window.removeEventListener('scroll', toggleVisibility);
      button.removeEventListener('click', scrollToTop);
    };
  };

  let destroyFloatingBtn: (() => void) | undefined;
  const runSetup = () => {
    destroyFloatingBtn?.();
    destroyFloatingBtn = initFloatingBackToTop();
  };

  runSetup();
  document.addEventListener('astro:page-load', runSetup);
  document.addEventListener('astro:after-swap', runSetup);
</script>
