---
import { SITE, type buildMeta as BuildMetaFn } from '@/consts';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Toast from '@/app/components/ui/Toast';
import Sidebar from '@/app/components/sidebar/Sidebar.astro';

interface Props {
  meta?: Partial<ReturnType<typeof BuildMetaFn>>;
  schema?: object | object[];
  isHome?: boolean;
  canonical?: string;
  hideHeader?: boolean;
  hideFooter?: boolean;
}

const { meta, schema, isHome = false, canonical, hideHeader = false, hideFooter = false } = Astro.props;

const sidebarState = Astro.cookies.get('sidebar_state')?.value || 'expanded';
---

<!DOCTYPE html>
<html lang={SITE.lang} dir={SITE.dir} data-sidebar={sidebarState}>
  <Head {meta} {schema} {isHome} {canonical}>
    <script is:inline>
      const getTheme = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('adogen-theme')) {
          return localStorage.getItem('adogen-theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };
      const theme = getTheme();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        document.documentElement.style.colorScheme = 'dark';
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.style.colorScheme = 'light';
      }
    </script>
  </Head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only fixed top-3 left-3 z-50 px-4! py-2 text-body-20 bg-(--accent) text-(--accent-fg) rounded-md shadow-lg focus:outline-none focus:ring-2 focus:ring-(--accent-ring)">
      Skip to content
    </a>
    {!hideHeader && (<Header />)}
    <div class="flex h-[calc(h-screen)-(--header-height)]">
      <Sidebar />
      <main id="main-content" class="flex-1">
        <slot />
      </main>
    </div>
    {!hideFooter && (<Footer />)}
    <Toast client:only="react" />
  </body>
</html>
